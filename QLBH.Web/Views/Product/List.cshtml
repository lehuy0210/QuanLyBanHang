@using System.Data
@model DataTable

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách sản phẩm</h2>
    <a href="/Product/Create" class="btn btn-success">
        + Thêm sản phẩm mới
    </a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã SP</th>
            <th>Tên sản phẩm</th>
            <th>Loại sản phẩm</th>
            <th>Nhà cung cấp</th>
            <th>Đơn giá</th>
            <th>Quy cách</th>
            <th class="text-center">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Rows.Count > 0)
        {
            foreach (DataRow row in Model.Rows)
            {
                <tr>
                    <td>@row["ProductID"]</td>
                    <td>@row["ProductName"]</td>
                    <td>@row["CategoryName"]</td>
                    <td>@row["CompanyName"]</td>
                    <td>@string.Format("{0:N2} USD", row["UnitPrice"])</td>
                    <td>@row["QuantityPerUnit"]</td>

                    <td class="text-center">
                        <a href="/Product/Edit/@row["ProductID"]" class="btn btn-warning btn-sm">
                            Sửa
                        </a>
                        <form asp-action="Delete" asp-controller="Product" method="post" style="display:inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm @row["ProductName"] không?');">
                            <input type="hidden" name="id" value="@row["ProductID"]" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Không có dữ liệu hiển thị.</td>
            </tr>
        }
    </tbody>
</table>