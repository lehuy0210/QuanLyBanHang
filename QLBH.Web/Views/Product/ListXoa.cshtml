@using System.Data
@model DataTable

@{
    Layout = "_Layout";
    ViewBag.Title = "Danh sách sản phẩm bị xóa";
}

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã SP</th>
            <th>Tên sản phẩm</th>
            <th>Loại sản phẩm</th>
            <th>Nhà cung cấp</th>
            <th>Đơn giá</th>
            <th>Quy cách</th>
            <th>SL trong kho</th>
            <th class="text-center">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Rows.Count > 0)
        {
            foreach (DataRow row in Model.Rows)
            {
                <tr>
                    <td>@row["ProductID"]</td>
                    <td>@row["ProductName"]</td>
                    <td>@row["CategoryName"]</td>
                    <td>@row["CompanyName"]</td>
                    <td>@string.Format("{0:N0} VNĐ", row["UnitPrice"])</td>
                    <td>@row["QuantityPerUnit"]</td>
                    <td>@row["UnitsInStock"]</td>
                    <td class="text-center">
                        <button class="btn btn-success btn-sm" onclick="goiApiBanLai(@row["ProductID"])">
                            Bán lại
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center">Không có dữ liệu hiển thị.</td>
            </tr>
        }
    </tbody>
</table>

<script>
    function goiApiBanLai(id) {
        if (confirm('Bạn có chắc chắn muốn bán lại sản phẩm này không?')) {

            const apiUrl = 'http://localhost:5003/api/Product/BanLai/' + id;

            fetch(apiUrl, {
                method: 'PUT',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                }
            })
            .then(response => {
                if (response.ok) {
                    alert('Đã bán lại sản phẩm thành công!');
                    window.location.reload();
                } else {
                    alert('Lỗi: Không thể khôi phục sản phẩm.');
                }
            })
            .catch(error => {
                console.error('Lỗi khi gọi API:', error);
                alert('Lỗi kết nối đến server.');
            });
        }
    }
</script>