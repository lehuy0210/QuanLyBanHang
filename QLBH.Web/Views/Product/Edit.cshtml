@using QLBH.DTO
@model ProductDTO

@{
    Layout = "_Layout";
    ViewBag.Title = "Sửa thông tin sản phẩm";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Lỗi!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Sửa thông tin sản phẩm</h2>
    <a href="/Product/List" class="btn btn-secondary">
        Quay lại danh sách
    </a>
</div>

@if (Model != null)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-controller="Product" method="post">
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input type="text" class="form-control" name="Name" value="@Model.Name" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Đơn giá (VNĐ)</label>
                        <input type="text" class="form-control" name="Price" value="@Model.Price" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Loại sản phẩm (Category)</label>
                        @Html.DropDownListFor(m => m.CateId,
                        new SelectList(Model.Categories, "Id", "Name"),
                                        "-- Select Category --",
                                        new { @class = "form-select", required = "required" })
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Nhà cung cấp (Supplier)</label>
                    @Html.DropDownListFor(m => m.SupId,
                                        new SelectList(Model.Suppliers, "Id", "Name"),
                                        "-- Select Supplier --",
                                        new { @class = "form-select", required = "required" })
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Quy cách</label>
                    <input type="text" class="form-control" name="Quantity" value="@Model.Quantity" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số lượng trong kho</label>
                    <input type="number" class="form-control" name="UnitsInStock" value="@Model.UnitsInStock" required />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                <button type="reset" class="btn btn-warning px-4">Nhập lại</button>
            </div>
        </form>
    </div>
</div>
}
else
{
    <div class="alert alert-danger text-center">
        Không tìm thấy thông tin sản phẩm hoặc dữ liệu bị lỗi!
    </div>
}