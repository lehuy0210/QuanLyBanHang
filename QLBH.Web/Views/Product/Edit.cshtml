@model ProductReq

@{
    ViewData["Title"] = "Sửa thông tin sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Sửa thông tin sản phẩm</h2>
    <a href="/Product/List" class="btn btn-secondary">Quay lại danh sách</a>
</div>

@if (Model != null)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-controller="Product" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input type="text" class="form-control" name="Name" value="@Model.Name" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Đơn giá</label>
                        <input type="number" min="0" step="0.01" class="form-control" name="Price" value="@Model.Price" required />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Loại sản phẩm</label>
                        @Html.DropDownListFor(m => m.CateId,
                            new SelectList(Model.Categories, "Id", "Name"),
                            "-- Chọn loại sản phẩm --",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nhà cung cấp</label>
                        @Html.DropDownListFor(m => m.SupId,
                            new SelectList(Model.Suppliers, "Id", "Name"),
                            "-- Chọn nhà cung cấp --",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Quy cách</label>
                        <input type="text" class="form-control" name="Quantity" value="@Model.Quantity" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                    <button type="reset" class="btn btn-warning px-4">Nhập lại</button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger text-center">
        Không tìm thấy thông tin sản phẩm hoặc dữ liệu bị lỗi!
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}