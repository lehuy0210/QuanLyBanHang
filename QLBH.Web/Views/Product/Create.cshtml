@model ProductReq

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Thêm sản phẩm mới</h2>
    <a href="/Product/List" class="btn btn-secondary">Quay lại danh sách</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-controller="Product" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Nhập tên sản phẩm" })
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Đơn giá</label>
                    @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01", placeholder = "0.00" })
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Nhà cung cấp</label>
                    @Html.DropDownListFor(m => m.SupId,
                        new SelectList(Model.Suppliers, "Id", "Name"),
                        "-- Chọn nhà cung cấp --",
                        new { @class = "form-select" })
                    <span asp-validation-for="SupId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Loại sản phẩm</label>
                    @Html.DropDownListFor(m => m.CateId,
                        new SelectList(Model.Categories, "Id", "Name"),
                        "-- Chọn loại sản phẩm --",
                        new { @class = "form-select" })
                    <span asp-validation-for="CateId" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Quy cách</label>
                    @Html.TextBoxFor(m => m.Quantity, new { @class = "form-control", placeholder = "VD: 12 hộp x 500ml" })
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">Thêm sản phẩm</button>
                <button type="reset" class="btn btn-warning px-4">Nhập lại</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}