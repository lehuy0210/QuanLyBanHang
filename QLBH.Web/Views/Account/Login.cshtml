<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">ĐĂNG NHẬP</h3>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                    {
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        if (ViewBag.ThongBaoLoi != null)
                        {
                            <div class="alert alert-danger text-center py-2 mb-3">
                                @ViewBag.ThongBaoLoi
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập:</label>
                            @Html.TextBox("Username", null, new { @class = "form-control", placeholder = "Nhập tên đăng nhập" })
                            <span class="text-danger small">@ViewData["Loi1"]</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu:</label>
                            @Html.Password("Password", null, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                            <span class="text-danger small">@ViewData["Loi2"]</span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Đăng nhập</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>