<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">ĐĂNG KÝ THÀNH VIÊN</h3>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger text-center py-2 mb-4">
                            @TempData["Error"]
                        </div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Họ tên khách hàng:</label>
                                @Html.TextBox("Name", null, new { @class = "form-control", placeholder = "Nhập họ và tên" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Điện thoại:</label>
                                @Html.TextBox("Phone", null, new { @class = "form-control", placeholder = "Nhập số điện thoại" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Tên đăng nhập:</label>
                                @Html.TextBox("Username", null, new { @class = "form-control", placeholder = "Chọn tên đăng nhập" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Mật khẩu:</label>
                                @Html.Password("Password", null, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Mật khẩu nhập lại:</label>
                                @Html.Password("Matkhaunhaplai", null, new { @class = "form-control", placeholder = "Xác nhận lại mật khẩu" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">(*) Địa chỉ:</label>
                                @Html.TextBox("Address", null, new { @class = "form-control", placeholder = "Nhập địa chỉ" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thành phố:</label>
                                @Html.TextBox("City", null, new { @class = "form-control", placeholder = "Tên thành phố" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Quốc gia:</label>
                                @Html.TextBox("Country", null, new { @class = "form-control", placeholder = "Tên quốc gia" })
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg">Đăng ký</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>