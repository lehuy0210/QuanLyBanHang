@model QLBH.DTO.CustomerDTO

@{
    Layout = "_LayoutHome";
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* CSS cho các hộp icon nhìn xịn sò hơn */
    .icon-box {
        width: 48px;
        height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row gx-lg-5">

        <div class="col-lg-4 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body text-center p-5">

                    <img src="https://ui-avatars.com/api/?name=@Model.Name&background=0D8ABC&color=fff&size=150&rounded=true&bold=true"
                         class="rounded-circle mb-4 shadow-sm" alt="Avatar" style="width: 130px; height: 130px; border: 4px solid #f8f9fa;">

                    <h4 class="fw-bold mb-2 text-dark">
                        @(string.IsNullOrWhiteSpace(Model.Name) ? "Chưa có tên" : Model.Name)
                    </h4>

                    <p class="text-muted mb-4">
                        <i class="bi bi-geo-alt me-1"></i>
                        @if (string.IsNullOrWhiteSpace(Model.City) && string.IsNullOrWhiteSpace(Model.Country))
                        {
                            <span class="fst-italic">Chưa cập nhật vị trí</span>
                        }
                        else
                        {
                            <span>@Model.City@(string.IsNullOrEmpty(Model.City) || string.IsNullOrEmpty(Model.Country) ? "" : ", ")@Model.Country</span>
                        }
                    </p>

                    <hr class="text-muted opacity-25 mb-4">

                    <div class="d-grid gap-2">
                        <a asp-action="EditCustomer" asp-controller="Customer" class="btn btn-primary rounded-pill py-2 fw-semibold shadow-sm">
                            <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa thông tin
                        </a>
                        <a href="/" class="btn btn-light rounded-pill py-2 text-secondary fw-semibold border">
                            <i class="bi bi-house me-2"></i> Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-header bg-transparent border-0 pt-5 pb-0 px-5">
                    <h5 class="fw-bold text-dark"><i class="bi bi-person-lines-fill text-primary me-2"></i>Thông tin chi tiết</h5>
                </div>

                <div class="card-body p-5">

                    <div class="row mb-4 align-items-center">
                        <div class="col-auto">
                            <div class="icon-box bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-telephone-fill fs-5"></i>
                            </div>
                        </div>
                        <div class="col">
                            <small class="text-muted d-block fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Số điện thoại</small>
                            @if (string.IsNullOrWhiteSpace(Model.Phone))
                            {
                                <span class="text-muted fst-italic">Chưa cập nhật. Vui lòng bấm "Chỉnh sửa" để thêm.</span>
                            }
                            else
                            {
                                <a href="tel:@Model.Phone" class="text-dark fw-bold text-decoration-none fs-5">@Model.Phone</a>
                            }
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-auto">
                            <div class="icon-box bg-success bg-opacity-10 text-success">
                                <i class="bi bi-house-door-fill fs-5"></i>
                            </div>
                        </div>
                        <div class="col">
                            <small class="text-muted d-block fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Địa chỉ nhà</small>
                            @if (string.IsNullOrWhiteSpace(Model.Address))
                            {
                                <span class="text-muted fst-italic">Chưa cập nhật địa chỉ. Vui lòng bấm "Chỉnh sửa" để thêm.</span>
                            }
                            else
                            {
                                <span class="text-dark fw-bold fs-6">@Model.Address</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-auto">
                            <div class="icon-box bg-info bg-opacity-10 text-info">
                                <i class="bi bi-building fs-5"></i>
                            </div>
                        </div>
                        <div class="col">
                            <small class="text-muted d-block fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Thành phố</small>
                            @if (string.IsNullOrWhiteSpace(Model.City))
                            {
                                <span class="text-muted fst-italic">Chưa cập nhật</span>
                            }
                            else
                            {
                                <span class="text-dark fw-bold fs-6">@Model.City</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-auto">
                            <div class="icon-box bg-warning bg-opacity-10 text-warning">
                                <i class="bi bi-globe-americas fs-5"></i>
                            </div>
                        </div>
                        <div class="col">
                            <small class="text-muted d-block fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Quốc gia</small>
                            @if (string.IsNullOrWhiteSpace(Model.Country))
                            {
                                <span class="text-muted fst-italic">Chưa cập nhật</span>
                            }
                            else
                            {
                                <span class="text-dark fw-bold fs-6">@Model.Country</span>
                            }
                        </div>

                </div>
            </div>
        </div>
    </div>
</div>