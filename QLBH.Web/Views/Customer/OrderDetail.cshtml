@model List<QLBH.DTO.OrderDTO>

@{
    Layout = "_LayoutHome";
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary bg-gradient text-white py-3">
            <h3 class="mb-0 fs-4"><i class="bi bi-clock-history me-2"></i>LỊCH SỬ ĐẶT HÀNG</h3>
        </div>

        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
            }
            else if (Model == null || Model.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x text-muted display-1"></i>
                    <p class="mt-3 fs-5 text-muted">Bạn chưa có đơn hàng nào.</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4">Mua sắm ngay</a>
                </div>
            }
            else
            {
                <p class="text-muted mb-4"><i class="bi bi-info-circle me-1"></i> Bấm vào mã đơn hàng để xem chi tiết sản phẩm.</p>

                <div class="accordion shadow-sm" id="accordionOrders">
                    @foreach (var orderGroup in Model.GroupBy(x => x.OrderID))
                    {
                        var collapseId = "collapse" + orderGroup.Key;
                        var headingId = "heading" + orderGroup.Key;

                        <div class="accordion-item border-bottom">
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button collapsed py-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                    <div class="d-flex justify-content-between w-100 align-items-center pe-3">
                                        <div>
                                            <span class="fw-bold text-primary fs-5">Mã đơn: #@orderGroup.Key</span>
                                            <span class="ms-3 badge bg-secondary-subtle text-secondary border">@orderGroup.Count() sản phẩm</span>
                                        </div>
                                        <div class="text-end">
                                            <span class="text-muted small d-block">Tổng thanh toán</span>
                                            <span class="fw-bold text-danger fs-5">@orderGroup.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#accordionOrders">
                                <div class="accordion-body bg-light-subtle">

                                    <div class="mb-3 px-2 text-dark">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                        <strong>Địa chỉ giao hàng:</strong> @orderGroup.First().Address
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0 bg-white">
                                            <thead class="table-light">
                                                <tr class="small text-uppercase text-secondary">
                                                    <th class="ps-3">Sản phẩm</th>
                                                    <th class="text-end">Đơn giá</th>
                                                    <th class="text-center">Số lượng</th>

                                                    <th class="text-end pe-3">Thành tiền</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in orderGroup)
                                                {
                                                    <tr>
                                                        <td class="ps-3 py-3">
                                                            <div class="fw-medium">@item.ProductName</div>
                                                        </td>
                                                        <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                                        <td class="text-center">@item.Quantity</td>

                                                        <td class="text-end pe-3 fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                <a href="/Home/Index" class="btn btn-light border px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Chỉnh nút Accordion để không bị viền xanh khi bấm */
    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(0,0,0,.125);
    }

    /* Màu nền khi mở rộng */
    .accordion-button:not(.collapsed) {
        background-color: #f8f9fa;
        color: #0d6efd;
    }

    /* Bo góc card */
    .card {
        border-radius: 15px;
    }

    .accordion-item:last-child {
        border-bottom: none !important;
    }
</style>