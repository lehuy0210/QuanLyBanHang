@model List<CustomerReq>

@{
    ViewData["Title"] = "Danh sách khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách khách hàng</h2>
    <a href="/Customer/Create" class="btn btn-success">+ Thêm khách hàng mới</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã KH</th>
            <th>Tên liên hệ</th>
            <th>Địa chỉ</th>
            <th>Thành phố</th>
            <th>Quốc gia</th>
            <th>Điện thoại</th>
            <th class="text-center">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var kh in Model)
            {
                <tr>
                    <td>@kh.Id</td>
                    <td>@kh.Name</td>
                    <td>@kh.Address</td>
                    <td>@kh.City</td>
                    <td>@kh.Country</td>
                    <td>@kh.Phone</td>
                    <td class="text-center">
                        <a href="/Customer/Edit/@kh.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <form asp-action="Delete" asp-controller="Customer" method="post" style="display:inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng @kh.Name không?');">
                            <input type="hidden" name="id" value="@kh.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Không có dữ liệu khách hàng.</td>
            </tr>
        }
    </tbody>
</table>