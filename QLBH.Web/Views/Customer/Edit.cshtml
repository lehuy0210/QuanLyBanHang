@model CustomerReq

@{
    ViewData["Title"] = "Sửa thông tin khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Sửa thông tin khách hàng</h2>
    <a href="/Customer/List" class="btn btn-secondary">Quay lại danh sách</a>
</div>

@if (Model != null)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-controller="Customer" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mã khách hàng</label>
                        <input type="text" class="form-control" value="@Model.Id" disabled />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên liên hệ</label>
                        <input type="text" class="form-control" name="Name" value="@Model.Name" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Địa chỉ</label>
                        <input type="text" class="form-control" name="Address" value="@Model.Address" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Thành phố</label>
                        <input type="text" class="form-control" name="City" value="@Model.City" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Quốc gia</label>
                        <input type="text" class="form-control" name="Country" value="@Model.Country" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Điện thoại</label>
                        <input type="text" class="form-control" name="Phone" value="@Model.Phone" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                    <button type="reset" class="btn btn-warning px-4">Nhập lại</button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger text-center">
        Không tìm thấy thông tin khách hàng!
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
