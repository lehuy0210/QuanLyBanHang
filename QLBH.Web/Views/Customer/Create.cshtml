@model CustomerReq

@{
    ViewData["Title"] = "Thêm khách hàng mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Thêm khách hàng mới</h2>
    <a href="/Customer/List" class="btn btn-secondary">Quay lại danh sách</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-controller="Customer" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Mã khách hàng (5 ký tự)</label>
                    @Html.TextBoxFor(m => m.Id, new { @class = "form-control", maxlength = "5", placeholder = "VD: ABCDE" })
                    <span asp-validation-for="Id" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên liên hệ</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Nhập tên liên hệ" })
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.Address, new { @class = "form-control", placeholder = "Nhập địa chỉ" })
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Thành phố</label>
                    @Html.TextBoxFor(m => m.City, new { @class = "form-control" })
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Quốc gia</label>
                    @Html.TextBoxFor(m => m.Country, new { @class = "form-control" })
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Điện thoại</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">Thêm khách hàng</button>
                <button type="reset" class="btn btn-warning px-4">Nhập lại</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
