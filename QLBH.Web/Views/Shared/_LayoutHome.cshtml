@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using QLBH.Common
@{
    // 1. Kiểm tra xem trong Session có dữ liệu đăng nhập chưa
    var userSessionData = Context.Session.GetString("UserSession");
    string tenKhachHang = null;

    // 2. Nếu có dữ liệu, tiến hành dịch cục JSON để lấy tên khách hàng
    if (!string.IsNullOrEmpty(userSessionData))
    {
        try
        {
            using (JsonDocument doc = JsonDocument.Parse(userSessionData))
            {
                var userInfo = doc.RootElement.GetProperty("userInfo");
                // API mặc định hay trả về chữ cái đầu viết thường (name) hoặc viết hoa (Name)
                if (userInfo.TryGetProperty("name", out var nameProp)) { tenKhachHang = nameProp.GetString(); }
                else if (userInfo.TryGetProperty("Name", out var NameProp)) { tenKhachHang = NameProp.GetString(); }
            }
        }
        catch
        {
            tenKhachHang = "Bạn"; // Phòng hờ lỗi parse JSON
        }
    }

    int countCart = 0; // Dòng này cực kỳ quan trọng, thiếu nó là báo lỗi ngay!
    List<OrderReq> currentCart = new List<OrderReq>();
    var sessionCart = Context.Session.GetString("CartSession");

    if (!string.IsNullOrEmpty(sessionCart))
    {
        try
        {
            var items = JsonSerializer.Deserialize<List<OrderReq>>(sessionCart);
            if (items != null)
            {
                currentCart = items;
                countCart = items.Sum(x => x.Quantity);
            }
        }
        catch
        {
            countCart = 0;
        }
    }

}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Bán Hàng</title>
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">QLBH</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item dropdown me-3">

                            <a class="nav-link text-white d-flex align-items-center dropdown-toggle" href="#" id="cartDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="position-relative d-inline-block">
                                    <span class="fs-4">🛒</span>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                          style="font-size: 0.65rem; padding: 0.25em 0.45em; transform: translate(-30%, -20%) !important;">
                                        @countCart  <span class="visually-hidden">sản phẩm</span>
                                    </span>
                                </div>
                                <span class="ms-2">Giỏ hàng</span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="cartDropdown" style="width: 320px;">
                                <li><h6 class="dropdown-header text-center py-2">Giỏ hàng của bạn</h6></li>
                                <li><hr class="dropdown-divider"></li>

                                @if (currentCart == null || !currentCart.Any())
                                {
                                    <li><span class="dropdown-item text-center text-muted py-3">Giỏ hàng đang trống</span></li>
                                }
                                else
                                {
                                    @foreach (var item in currentCart)
                                    {
                                        <li>
                                            <div class="dropdown-item d-flex justify-content-between align-items-center py-2">
                                                <div style="flex: 1;">
                                                    <span class="fw-bold d-block text-truncate" style="max-width: 150px;">@item.ProductName</span>
                                                    <small class="text-muted">SL: @item.Quantity x @item.UnitPrice.ToString("N0")đ</small>
                                                </div>
                                                <span class="text-danger fw-bold ms-2">@((item.Quantity * item.UnitPrice).ToString("N0"))đ</span>
                                            </div>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="p-2">
                                        <a class="btn btn-primary btn-sm w-100 p-2 shadow-sm" href="/Order/Index">Xem chi tiết hóa đơn</a>
                                    </li>
                                }
                            </ul>

                        @if (tenKhachHang != null)
                        {
                            <li class="nav-item me-3">
                                <span class="nav-link text-warning fw-bold">Xin chào, @tenKhachHang!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>

    @{
        var thongBao = TempData["ThongBao"] as string;
    }
    @if (!string.IsNullOrEmpty(thongBao))
    {
        <script>
            alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(thongBao)));
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>