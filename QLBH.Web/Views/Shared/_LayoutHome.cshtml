@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using QLBH.DTO
@{
    // 1. Lấy thông tin User từ Session
    var userSessionData = Context.Session.GetString("UserSession");
    string tenKhachHang = null;
    string idKhachHang = null;

    if (!string.IsNullOrEmpty(userSessionData))
    {
        try
        {
            using (JsonDocument doc = JsonDocument.Parse(userSessionData))
            {
                var userInfo = doc.RootElement.GetProperty("userInfo");
                if (userInfo.TryGetProperty("name", out var nameProp)) { tenKhachHang = nameProp.GetString(); }
                else if (userInfo.TryGetProperty("Name", out var NameProp)) { tenKhachHang = NameProp.GetString(); }

                if (userInfo.TryGetProperty("id", out var idProp)) { idKhachHang = idProp.ToString(); }
                else if (userInfo.TryGetProperty("Id", out var IdProp)) { idKhachHang = IdProp.ToString(); }
                else if (userInfo.TryGetProperty("customerId", out var cusIdProp)) { idKhachHang = cusIdProp.ToString(); }
            }
        }
        catch { tenKhachHang = "Bạn"; }
    }

    // 2. Lấy thông tin Giỏ hàng
    int countCart = 0;
    List<OrderDTO> currentCart = new List<OrderDTO>();
    var sessionCart = Context.Session.GetString("CartSession");

    if (!string.IsNullOrEmpty(sessionCart))
    {
        try
        {
            var items = JsonSerializer.Deserialize<List<OrderDTO>>(sessionCart);
            if (items != null)
            {
                currentCart = items;
                countCart = items.Sum(x => x.Quantity);
            }
        }
        catch { countCart = 0; }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NHOM20Store</title>
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4 py-3 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4" href="/">
                    <i class="bi bi-shop me-2"></i>NHOM20Store
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">

                    @* MENU TRÁI (Đang để trống, bạn có thể thêm các link Trang chủ, Sản phẩm... vào đây sau) *@
                    <ul class="navbar-nav me-auto"></ul>

                    @* THANH TÌM KIẾM Ở GIỮA *@
                    <div class="mx-auto" style="max-width: 500px; width: 100%;">
                        <div class="input-group">
                            <input id="searchInput" type="search"
                                   class="form-control rounded-start-pill border-primary ps-4 shadow-none"
                                   placeholder="Bạn tìm gì hôm nay?..." autocomplete="off">

                            <button class="btn btn-primary rounded-end-pill px-4" type="button">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    @* MENU PHẢI (GIỎ HÀNG & USER INFO) *@
                    <ul class="navbar-nav ms-auto align-items-center">
                        @* CHỈ HIỆN GIỎ HÀNG KHI ĐÃ ĐĂNG NHẬP *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown me-4">
                                <a class="nav-link text-dark d-flex align-items-center dropdown-toggle" href="#" id="cartDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="position-relative d-inline-block">
                                        <i class="bi bi-cart3 fs-4"></i>
                                        @if (countCart > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.7rem; padding: 0.35em 0.5em;">
                                                @countCart
                                            </span>
                                        }
                                    </div>
                                    <span class="ms-2 fw-semibold">Giỏ hàng</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3 mt-2" style="width: 340px;">
                                    <li><h6 class="dropdown-header text-center py-2 fw-bold text-primary">Giỏ hàng của bạn</h6></li>
                                    <li><hr class="dropdown-divider mb-0"></li>

                                    @if (!currentCart.Any())
                                    {
                                        <li>
                                            <div class="dropdown-item text-center text-muted py-4">
                                                <i class="bi bi-cart-x fs-1 text-light d-block mb-2"></i>
                                                Giỏ hàng đang trống
                                            </div>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <div style="max-height: 300px; overflow-y: auto;">
                                                @foreach (var item in currentCart)
                                                {
                                                    <div class="dropdown-item d-flex justify-content-between align-items-center py-3 border-bottom text-wrap">
                                                        <div style="flex: 1;" class="pe-2">
                                                            <span class="fw-bold d-block" style="font-size: 0.9rem;">@item.ProductName</span>
                                                            <small class="text-muted">SL: @item.Quantity x @item.UnitPrice.ToString("N0")đ</small>
                                                        </div>
                                                        <span class="text-danger fw-bold ms-2">@((item.Quantity * item.UnitPrice).ToString("N0"))đ</span>
                                                    </div>
                                                }
                                            </div>
                                        </li>
                                        <li class="p-3 bg-light rounded-bottom">
                                            <a class="btn btn-primary w-100 fw-bold shadow-sm" href="/Order/Index">
                                                <i class="bi bi-credit-card me-2"></i>Thanh toán ngay
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @* HIỆN TÊN USER HOẶC NÚT ĐĂNG NHẬP *@
                        @if (tenKhachHang != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark d-flex align-items-center dropdown-toggle cursor-pointer" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="https://ui-avatars.com/api/?name=@tenKhachHang&background=0D8ABC&color=fff&size=128&rounded=true&bold=true"
                                         class="rounded-circle me-2 border border-primary border-opacity-25 shadow-sm"
                                         alt="Avatar"
                                         style="width: 35px; height: 35px; object-fit: cover;">
                                    <span>Xin chào, <strong class="text-primary">@tenKhachHang</strong>!</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item py-2" href="/Customer/Information/@idKhachHang">
                                            <i class="bi bi-person-badge me-2 text-primary"></i>Thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" href="/Customer/OrderDetail">
                                            <i class="bi bi-box-seam me-2 text-primary"></i>Đơn hàng của tôi
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger fw-bold" href="/Account/Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-primary fw-semibold rounded-pill px-4" href="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary fw-semibold rounded-pill px-4 shadow-sm" href="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* PHẦN THÔNG BÁO *@
        @{
            var thongBao = TempData["ThongBao"] as string;
        }
        @if (!string.IsNullOrEmpty(thongBao))
        {
            <div id="msgAlert" class="alert alert-info alert-dismissible fade show shadow-sm border-0 bg-white border-start border-4 border-info" role="alert">
                <i class="bi bi-bell-fill text-info me-2 fs-5 align-middle"></i>
                <span class="fw-semibold text-dark">@thongBao</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <script>
                setTimeout(() => {
                    var alertElement = document.getElementById('msgAlert');
                    if (alertElement) {
                        // Khởi tạo instance của Bootstrap Alert
                        var bsAlert = new bootstrap.Alert(alertElement);
                        // Gọi lệnh đóng
                        bsAlert.close();
                    }
                }, 4000); // 4 giây
            </script>
        }

        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        $(document).ready(function () {
            let timeout = null;

            // --- PHẦN 1: XỬ LÝ LIVE SEARCH (TEXT CHANGED) ---
            $('#searchInput').on('input', function () {
                clearTimeout(timeout);
                let keyword = $(this).val().trim();

                // Nếu ô nhập trống thì gọi API lấy toàn bộ danh sách
                let url = (keyword === "")
                          ? 'http://localhost:5003/api/Product/List'
                          : 'http://localhost:5003/api/Product/Search';
                let data = (keyword === "") ? {} : { tukhoa: keyword };

                timeout = setTimeout(function () {
                    $.ajax({
                        url: url,
                        type: 'GET',
                        data: data,
                        success: function (res) {
                            renderProducts(res); // Gọi hàm vẽ lại giao diện
                        }
                    });
                }, 400);
            });

            // --- PHẦN 2: HÀM VẼ GIAO DIỆN SẢN PHẨM ---
            function renderProducts(res) {
                let html = '';
                if (res && res.length > 0) {
                    res.forEach(item => {
                        let name = item.productName || item.ProductName;
                        let price = item.unitPrice || item.UnitPrice;
                        let id = item.productID || item.productId || item.ProductID;
                        let cat = item.categoryName || item.CategoryName || 'N/A';

                        html += `
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <img src="https://placehold.co/300x200?text=SP" class="card-img-top">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold">${name}</h5>
                                    <div class="mb-2"><span class="badge bg-info text-dark">${cat}</span></div>
                                    <h5 class="card-text text-danger fw-bold mt-auto mb-3">${Number(price).toLocaleString()} đ</h5>

                                    <form class="add-to-cart-form">
                                        <input type="hidden" name="productId" value="${id}" />
                                        <input type="hidden" name="productName" value="${name}" />
                                        <input type="hidden" name="unitPrice" value="${price}" />
                                        <div class="d-flex align-items-center mt-3">
                                            <div class="input-group input-group-sm me-2" style="width: 100px;">
                                                <span class="input-group-text">SL</span>
                                                <input type="number" name="quantity" value="1" min="1" class="form-control" />
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-sm flex-grow-1 shadow-sm">
                                                <i class="bi bi-cart-plus"></i> Mua ngay
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>`;
                    });
                } else {
                    html = '<div class="col-12 text-center py-5"><h4>Không tìm thấy sản phẩm.</h4></div>';
                }
                $('#productContainer').html(html);
            }

            // --- PHẦN 3: XỬ LÝ THÊM VÀO GIỎ HÀNG (KHÔNG LOAD LẠI TRANG) ---
            // Dùng $(document).on vì các Form được tạo ra động bằng JS
            $(document).on('submit', '.add-to-cart-form', function (e) {
                e.preventDefault(); // CHẶN LỆNH LOAD LẠI TRANG

                let form = $(this);
                $.ajax({
                    url: '/Order/AddToCart', // Đường dẫn Controller MVC của bạn
                    type: 'POST',
                    success: function (res) {
                    // Hiện thông báo từ JSON Server trả về
                    alert(res.message);

                    if (res.success) {
                        // Nếu thành công thì nạp lại trang để cập nhật số lượng trên menu
                        location.reload();
                    }
                },
                error: function () {
                    alert("Lỗi kết nối server!");
                }
                });
            });
        });
    </script>

</body>
</html>