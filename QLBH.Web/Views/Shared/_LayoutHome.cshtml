@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using QLBH.Common
@{
    // 1. Lấy thông tin User từ Session
    var userSessionData = Context.Session.GetString("UserSession");
    string tenKhachHang = null;

    if (!string.IsNullOrEmpty(userSessionData))
    {
        try
        {
            using (JsonDocument doc = JsonDocument.Parse(userSessionData))
            {
                var userInfo = doc.RootElement.GetProperty("userInfo");
                if (userInfo.TryGetProperty("name", out var nameProp)) { tenKhachHang = nameProp.GetString(); }
                else if (userInfo.TryGetProperty("Name", out var NameProp)) { tenKhachHang = NameProp.GetString(); }
            }
        }
        catch { tenKhachHang = "Bạn"; }
    }

    // 2. Lấy thông tin Giỏ hàng
    int countCart = 0;
    List<OrderReq> currentCart = new List<OrderReq>();
    var sessionCart = Context.Session.GetString("CartSession");

    if (!string.IsNullOrEmpty(sessionCart))
    {
        try
        {
            var items = JsonSerializer.Deserialize<List<OrderReq>>(sessionCart);
            if (items != null)
            {
                currentCart = items;
                countCart = items.Sum(x => x.Quantity);
            }
        }
        catch { countCart = 0; }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NHOM20Store</title>
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4 py-3 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4" href="/">
                    <i class="bi bi-shop me-2"></i>NHOM20Store
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1"></ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @* CHỈ HIỆN GIỎ HÀNG KHI ĐÃ ĐĂNG NHẬP *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown me-4">
                                <a class="nav-link text-dark d-flex align-items-center dropdown-toggle" href="#" id="cartDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="position-relative d-inline-block">
                                        <i class="bi bi-cart3 fs-4"></i>
                                        @if (countCart > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.7rem; padding: 0.35em 0.5em;">
                                                @countCart
                                            </span>
                                        }
                                    </div>
                                    <span class="ms-2 fw-semibold">Giỏ hàng</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3 mt-2" style="width: 340px;">
                                    <li><h6 class="dropdown-header text-center py-2 fw-bold text-primary">Giỏ hàng của bạn</h6></li>
                                    <li><hr class="dropdown-divider mb-0"></li>

                                    @if (!currentCart.Any())
                                    {
                                        <li>
                                            <div class="dropdown-item text-center text-muted py-4">
                                                <i class="bi bi-cart-x fs-1 text-light d-block mb-2"></i>
                                                Giỏ hàng đang trống
                                            </div>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <div style="max-height: 300px; overflow-y: auto;">
                                                @foreach (var item in currentCart)
                                                {
                                                    <div class="dropdown-item d-flex justify-content-between align-items-center py-3 border-bottom text-wrap">
                                                        <div style="flex: 1;" class="pe-2">
                                                            <span class="fw-bold d-block" style="font-size: 0.9rem;">@item.ProductName</span>
                                                            <small class="text-muted">SL: @item.Quantity x @item.UnitPrice.ToString("N0")đ</small>
                                                        </div>
                                                        <span class="text-danger fw-bold ms-2">@((item.Quantity * item.UnitPrice).ToString("N0"))đ</span>
                                                    </div>
                                                }
                                            </div>
                                        </li>
                                        <li class="p-3 bg-light rounded-bottom">
                                            <a class="btn btn-primary w-100 fw-bold shadow-sm" href="/Order/Index">
                                                <i class="bi bi-credit-card me-2"></i>Thanh toán ngay
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @* HIỆN TÊN USER HOẶC NÚT ĐĂNG NHẬP *@
                        @if (tenKhachHang != null)
                        {
                            <li class="nav-item me-3">
                                <span class="nav-link text-dark">
                                    <i class="bi bi-person-circle text-primary me-1 fs-5 align-middle"></i>
                                    Xin chào, <strong class="text-primary">@tenKhachHang</strong>!
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm fw-semibold rounded-pill px-3" href="/Account/Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-primary fw-semibold rounded-pill px-4" href="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary fw-semibold rounded-pill px-4 shadow-sm" href="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* PHẦN THÔNG BÁO *@
        @{
            var thongBao = TempData["ThongBao"] as string;
        }
        @if (!string.IsNullOrEmpty(thongBao))
        {
            <div id="msgAlert" class="alert alert-info alert-dismissible fade show shadow-sm border-0 bg-white border-start border-4 border-info" role="alert">
                <i class="bi bi-bell-fill text-info me-2 fs-5 align-middle"></i>
                <span class="fw-semibold text-dark">@thongBao</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <script>
                setTimeout(() => {
                    var alertElement = document.getElementById('msgAlert');
                    if (alertElement) {
                        // Khởi tạo instance của Bootstrap Alert
                        var bsAlert = new bootstrap.Alert(alertElement);
                        // Gọi lệnh đóng
                        bsAlert.close();
                    }
                }, 4000); // 4 giây
            </script>
        }

        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>