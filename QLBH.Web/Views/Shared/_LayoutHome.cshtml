@using Microsoft.AspNetCore.Http
@using System.Text.Json

@{
    // 1. Kiểm tra xem trong Session có dữ liệu đăng nhập chưa
    var userSessionData = Context.Session.GetString("UserSession");
    string tenKhachHang = null;

    // 2. Nếu có dữ liệu, tiến hành dịch cục JSON để lấy tên khách hàng
    if (!string.IsNullOrEmpty(userSessionData))
    {
        try
        {
            using (JsonDocument doc = JsonDocument.Parse(userSessionData))
            {
                var userInfo = doc.RootElement.GetProperty("userInfo");
                // API mặc định hay trả về chữ cái đầu viết thường (name) hoặc viết hoa (Name)
                if (userInfo.TryGetProperty("name", out var nameProp)) { tenKhachHang = nameProp.GetString(); }
                else if (userInfo.TryGetProperty("Name", out var NameProp)) { tenKhachHang = NameProp.GetString(); }
            }
        }
        catch
        {
            tenKhachHang = "Bạn"; // Phòng hờ lỗi parse JSON
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Bán Hàng</title>
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">QLBH</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-3">
                            <a class="nav-link text-white d-flex align-items-center" href="/Cart/Index">
                                <span class="fs-5 me-1">🛒</span> Giỏ hàng
                                <span class="badge bg-danger rounded-pill ms-2">0</span>
                            </a>
                        </li>

                        @if (tenKhachHang != null)
                        {
                            <li class="nav-item me-3">
                                <span class="nav-link text-warning fw-bold">Xin chào, @tenKhachHang!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>

    @{
        var thongBao = TempData["ThongBao"] as string;
    }
    @if (!string.IsNullOrEmpty(thongBao))
    {
        <script>
            alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(thongBao)));
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>