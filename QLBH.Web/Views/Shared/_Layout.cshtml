<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary bg-gradient shadow mb-4 py-3">
            <div class="container-fluid">

                <a class="navbar-brand text-warning fw-bold fs-4 me-5" href="/Product/List">
                    <i class="bi bi-shield-lock-fill me-2"></i>ADMIN DASHBOARD
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 fw-semibold">
                        <li class="nav-item me-2">
                            <a class="nav-link text-white" href="/Product/List">
                                <i class="bi bi-box-seam me-1"></i>Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item me-2">
                            <a class="nav-link text-white" href="/Customer/List">
                                <i class="bi bi-people-fill me-1"></i>Khách hàng
                            </a>
                        </li>
                        <li class="nav-item me-2">
                            <a class="nav-link text-white" href="/Order/List">
                                <i class="bi bi-receipt me-1"></i>Đơn hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Employee/List">
                                <i class="bi bi-person-badge-fill me-1"></i>Nhân viên
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <span class="text-light">
                                <i class="bi bi-person-circle me-1"></i>Xin chào, <strong class="text-warning">@User.Identity.Name</strong>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm fw-bold" href="/Account/Logout">
                                <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-5">
            <div class="bg-white p-4 rounded-3 shadow-sm border border-light">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>