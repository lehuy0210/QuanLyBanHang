@using System.Data
@model DataTable

@{
    Layout = "_Layout";
    ViewBag.Title = "Danh sách đơn hàng";
}

@* @if (TempData["ThongBao"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <strong>Thông báo:</strong> @TempData["ThongBao"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
} *@

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách Đơn hàng</h2>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Mã ĐH</th>
                <th>Tên Khách Hàng</th>
                <th class="text-center">Số Lượng</th>
                <th class="text-end">Thành Tiền</th>
                <th>Ngày đặt hàng</th>
                <th class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Rows.Count > 0)
            {
                foreach (DataRow row in Model.Rows)
                {
                    <tr>
                        <td class="fw-bold">#@row["OrderID"]</td>
                        <td class="text-primary">@row["ContactName"]</td>
                        <td class="text-center">@row["Quantity"]</td>
                        <td class="text-end fw-bold text-danger">@row["TotalPrice"]</td>
                        <td>@Convert.ToDateTime(row["OrderDate"]).ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a href="/Order/Detail/@row["OrderID"]" class="btn btn-info btn-sm text-white">Xem</a>
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    onclick="xoaDonHang(@row["OrderID"])">
                                Xóa
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        <i>Chưa có đơn hàng nào trong hệ thống.</i>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <script>
        function xoaDonHang(orderId) {
            if (!confirm('Bạn có chắc muốn xóa đơn hàng #' + orderId + ' không?')) {
                return;
            }

            // SỬA QUAN TRỌNG: Phải thêm http://localhost:5003 (hoặc port thật của API) vào đây
            fetch('http://localhost:5003/api/Order/' + orderId, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(async response => {
                const textData = await response.text();

                if (response.ok) {
                    alert('Xóa đơn hàng thành công!');
                    window.location.reload();
                    return;
                }

                // Đoạn code gán mã lỗi đã được đặt đúng vị trí bên trong then()
                let errorMessage = "Lỗi " + response.status + ": Server không gửi kèm thông báo chi tiết.";

                if (textData) {
                    try {
                        const jsonData = JSON.parse(textData);
                        // Bắt các kiểu format Message khác nhau
                        errorMessage = jsonData.Message || jsonData.message || jsonData.title || textData;
                    } catch (e) {
                        errorMessage = textData;
                    }
                }

                throw new Error(errorMessage);
            })
            .catch(error => {
                console.error('Lỗi chi tiết:', error);
                alert('Lỗi khi xóa: ' + error.message);
            });
        }
    </script>
</div>