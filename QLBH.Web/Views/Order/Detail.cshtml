@model List<QLBH.Common.OrderReq>

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Chi tiết đơn hàng</h2>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }
    else if (Model != null && Model.Count > 0)
    {
        var firstItem = Model.First(); // Lấy dòng đầu tiên để hiển thị thông tin chung

        <div class="card mb-4 shadow-sm">
            <div class="card-body bg-light">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="card-title text-danger">Mã đơn hàng: #@firstItem.OrderID</h5>
                        <p class="card-text mb-0"><strong>Tên khách hàng:</strong> @firstItem.ContactName</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p class="card-text mb-0"><strong>Ngày in:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th width="5%">STT</th>
                        <th width="35%">Tên sản phẩm</th>
                        <th width="20%">Đơn giá</th>
                        <th width="15%">Số lượng</th>
                        <th width="25%">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                        decimal tongTienDonHang = 0;
                    }
                    @foreach (var item in Model)
                    {
                        tongTienDonHang += item.TotalPrice;
                        <tr>
                            <td class="text-center">@stt</td>
                            <td>@item.ProductName</td>
                            <td class="text-end">@item.UnitPrice.ToString("N0") VNĐ</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end text-danger fw-bold">@item.TotalPrice.ToString("N0") VNĐ</td>
                        </tr>
                        stt++;
                    }
                </tbody>
                <tfoot>
                    <tr class="table-warning">
                        <td colspan="4" class="text-end fw-bold fs-5">Tổng cộng toàn bộ hóa đơn:</td>
                        <td class="text-end text-danger fw-bold fs-5">@tongTienDonHang.ToString("N0") VNĐ</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="mt-3">
            <a href="/Order/List" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
            <button class="btn btn-primary float-end" onclick="window.print()">
                <i class="bi bi-printer"></i> In đơn hàng
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Không có dữ liệu chi tiết cho đơn hàng này.
        </div>
        <a href="/Order/List" class="btn btn-secondary mt-2">Quay lại</a>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>