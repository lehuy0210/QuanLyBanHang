@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <div class="display-1 text-success anim-popin">
                    <span class="p-3 border border-success rounded-circle">✔️</span>
                </div>
            </div>

            <h1 class="fw-bold text-dark">ĐẶT HÀNG THÀNH CÔNG!</h1>
            <p class="text-muted fs-5">
                Cảm ơn bạn đã tin tưởng mua sắm. Nhân viên chúng tôi sẽ sớm liên hệ để xác nhận đơn hàng.
            </p>

            <div class="card bg-light border-0 rounded-4 my-5 shadow-sm">
                <div class="card-body p-4">
                    <p class="text-uppercase small fw-bold text-secondary mb-2">Mã số hóa đơn của bạn</p>
                    <h2 class="display-5 fw-bold text-primary mb-0">#@ViewBag.OrderId</h2>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="/" class="btn btn-outline-dark px-4 py-2">
                    🏠 Quay về trang chủ
                </a>
                <button onclick="window.print()" class="btn btn-primary px-4 py-2">
                    🖨️ In hóa đơn này
                </button>
            </div>

            <p class="mt-4 text-muted small italic">
                Lưu ý: Bạn có thể kiểm tra trạng thái đơn hàng trong mục "Lịch sử mua hàng".
            </p>
        </div>
    </div>
</div>

<style>
    .anim-popin {
        animation: popin 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @@keyframes popin {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>